# Copy to .env and fill in. Do not commit .env.

# LLM — Gestalt uses Google Gemini by default (CrewAI + LiteLLM).
# Get a key: https://aistudio.google.com/app/apikey
# GEMINI_API_KEY=
# Alternative env name (same key; optional if GEMINI_API_KEY is set)
# GOOGLE_API_KEY=

# Optional: override model for CrewAI (LiteLLM id, default: gemini/gemini-2.5-flash)
# GESTALT_LLM_MODEL=gemini/gemini-2.5-flash

# Optional: model for tests/test_gemini_smoke.py only (google.genai native id)
# GESTALT_GEMINI_SMOKE_MODEL=gemini-2.5-flash

# Optional: model for "Explain Like I'm a Beginner" (google.genai native id; falls back to GESTALT_GEMINI_SMOKE_MODEL or gemini-2.5-flash)
# GESTALT_ELI5_MODEL=gemini-2.5-flash

# Optional tooling (enable when used)
# SERPER_API_KEY=

# Rainforest API (amazon_api.get_amazon_price)
# RAINFOREST_API_KEY=

# ScrapingBee (ebay_api.get_ebay_price)
# SCRAPINGBEE_API_KEY=

# Estimated “PC build service fee” as a fraction of parts total (default 0.12 = 12%).
# Used in pricing rollup with cross-retailer savings for the UI savings line.
# GESTALT_PC_BUILD_SERVICE_RATE=0.12
