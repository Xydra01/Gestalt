# Copy to .env and fill in. Do not commit .env.

# LLM — Gestalt uses Google Gemini by default (CrewAI + LiteLLM).
# Get a key: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
# Alternative env name (same key; optional if GEMINI_API_KEY is set)
# GOOGLE_API_KEY=

# Optional: override model id (default: gemini/gemini-1.5-flash)
# GESTALT_LLM_MODEL=gemini/gemini-2.0-flash

# Optional: model for tests/test_gemini_smoke.py only (native id, e.g. gemini-2.0-flash)
# GESTALT_GEMINI_SMOKE_MODEL=gemini-1.5-flash

# Optional tooling (enable when used)
# SERPER_API_KEY=
